	<script type="text/javascript"> 
	 
 
 		function cambiarOpacidad(){
			/*
			Estas dos propiedades no son validables por W3C, pero son necesarias para mostrar una capa con transparencia
			filter: alpha(opacity=50); 
			opacity: .5;
			
			*/
			
			       
			var popupVisible=false;
			var capa=document.getElementById('capa_oculta');	
			if (capa!=null){			
				capa.style.filter = "alpha(opacity=50)";
				capa.style.opacity = ".5";
			}
		
		}
		
		if (document.addEventListener) { 
			document.addEventListener("DOMContentLoaded", cambiarOpacidad, false);
   		} else { // IE 
			 attachEvent("onload",cambiarOpacidad);
		}

 
	</script>
